---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CTA from '@components/CTA.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id.split('/')[0] },
    props: { project },
  }));
}

interface Props {
  project: any;
}

const { project } = Astro.props;
const { html } = await project.render?.() || { html: '' };
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <div class="project-detail">
    <div class="container">
      <div class="breadcrumb">
        <a href="/projects">Projects</a>
        <span>/</span>
        <span>{project.data.title}</span>
      </div>

      {
        project.data.image && (
          <div class="project-hero-image">
            <img src={project.data.image} alt={project.data.title} />
          </div>
        )
      }

      <article>
        <header>
          <div class="project-meta">
            <span class="category">{project.data.category}</span>
            {project.data.date && <span class="date">{project.data.date.toLocaleDateString()}</span>}
          </div>
          <h1>{project.data.title}</h1>
          <p class="lead">{project.data.description}</p>
        </header>

        <div class="content" set:html={html} />
      </article>
    </div>
  </div>

  <CTA
    title="Have a Similar Project in Mind?"
    description="Let's discuss how we can help with your geotechnical engineering needs."
    buttons={[
      {
        text: 'Get in Touch',
        href: '/contact',
        variant: 'accent',
      },
      {
        text: 'View More Projects',
        href: '/projects',
        variant: 'secondary',
      },
    ]}
    background="primary"
  />
</BaseLayout>

<style>
  .project-detail {
    padding: var(--space-4xl) 0;
  }

  .breadcrumb {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    font-size: var(--font-size-sm);
    color: var(--color-gray);
  }

  .breadcrumb a {
    color: var(--color-primary);
  }

  .project-hero-image {
    margin: var(--space-2xl) 0 var(--space-3xl);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .project-hero-image img {
    width: 100%;
    height: auto;
    display: block;
    max-height: 500px;
    object-fit: cover;
  }

  article {
    max-width: 900px;
  }

  article header {
    margin-bottom: var(--space-3xl);
    border-bottom: 2px solid var(--color-light-gray);
    padding-bottom: var(--space-2xl);
  }

  .project-meta {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
    margin-bottom: var(--space-lg);
    font-size: var(--font-size-sm);
  }

  .category {
    display: inline-block;
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .date {
    color: var(--color-gray);
  }

  article h1 {
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
  }

  .lead {
    font-size: var(--font-size-lg);
    color: var(--color-gray);
    line-height: var(--line-height-relaxed);
  }

  .content {
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--color-dark-gray);
  }

  .content :global(h2) {
    color: var(--color-primary);
    margin-top: var(--space-2xl);
  }

  .content :global(h3) {
    color: var(--color-secondary);
  }

  .content :global(ul),
  .content :global(ol) {
    margin-left: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .content :global(li) {
    margin-bottom: var(--space-sm);
  }

  @media (max-width: 768px) {
    .project-detail {
      padding: var(--space-2xl) 0;
    }

    article header {
      padding-bottom: var(--space-lg);
    }

    article h1 {
      font-size: var(--font-size-3xl);
    }

    .project-meta {
      flex-wrap: wrap;
    }
  }
</style>
