---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CTA from '@components/CTA.astro';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service },
  }));
}

interface Props {
  service: any;
}

const { service } = Astro.props;
const { html } = await service.render?.() || { html: '' };
---

<BaseLayout title={service.data.title} description={service.data.description}>
  <div class="service-detail">
    <div class="container">
      <div class="breadcrumb">
        <a href="/BalconesGeotech/services">Services</a>
        <span>/</span>
        <span>{service.data.title}</span>
      </div>

      <article>
        <header>
          <h1>{service.data.title}</h1>
          <p class="lead">{service.data.description}</p>
        </header>

        <div class="content" set:html={html} />
      </article>
    </div>
  </div>

  <CTA
    title="Ready to Get Started?"
    description="Contact our team to learn how this service can benefit your project."
    buttons={[
      {
        text: 'Contact Us',
        href: '/BalconesGeotech/contact',
        variant: 'accent',
      },
      {
        text: 'View Other Services',
        href: '/BalconesGeotech/services',
        variant: 'secondary',
      },
    ]}
    background="secondary"
  />
</BaseLayout>

<style>
  .service-detail {
    padding: var(--space-4xl) 0;
  }

  .breadcrumb {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    font-size: var(--font-size-sm);
    color: var(--color-gray);
  }

  .breadcrumb a {
    color: var(--color-primary);
  }

  article {
    max-width: 900px;
  }

  article header {
    margin-bottom: var(--space-3xl);
    border-bottom: 2px solid var(--color-light-gray);
    padding-bottom: var(--space-2xl);
  }

  article h1 {
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
  }

  .lead {
    font-size: var(--font-size-lg);
    color: var(--color-gray);
    line-height: var(--line-height-relaxed);
  }

  .content {
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--color-dark-gray);
  }

  .content :global(h2) {
    color: var(--color-primary);
    margin-top: var(--space-2xl);
  }

  .content :global(h3) {
    color: var(--color-secondary);
  }

  .content :global(ul),
  .content :global(ol) {
    margin-left: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .content :global(li) {
    margin-bottom: var(--space-sm);
  }

  @media (max-width: 768px) {
    .service-detail {
      padding: var(--space-2xl) 0;
    }

    article header {
      padding-bottom: var(--space-lg);
    }

    article h1 {
      font-size: var(--font-size-3xl);
    }
  }
</style>
