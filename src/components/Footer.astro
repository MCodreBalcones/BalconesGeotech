---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <h4>Balcones Geotech</h4>
        <p>Professional geotechnical engineering services for infrastructure projects.</p>
      </div>

      <div class="footer-section">
        <h5>Quick Links</h5>
        <ul>
          <li><a href="/services">Services</a></li>
          <li><a href="/projects">Projects</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h5>Services</h5>
        <ul>
          <li><a href="/services/geotechnical-engineering">Geotechnical Engineering</a></li>
          <li><a href="/services/site-investigation">Site Investigation</a></li>
          <li><a href="/services/forensic-failure-analysis">Forensic & Failure Analysis</a></li>
          <li><a href="/services/pavement-engineering">Pavement Engineering</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h5>Contact Info</h5>
        <p>
          <strong>Phone:</strong><br />
          <a href="tel:+15123809969">(512) 380-9969</a>
        </p>
        <p>
          <strong>Email:</strong><br />
          <a href="mailto:rrusso@balconesgeotech.com">rrusso@balconesgeotech.com</a>
        </p>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Balcones Geotech. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-dark-gray);
    color: var(--color-white);
    margin-top: var(--space-4xl);
    padding: var(--space-4xl) 0 var(--space-lg);
  }

  .footer a {
    color: var(--color-primary-light);
  }

  .footer a:hover {
    color: var(--color-accent);
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-2xl);
    margin-bottom: var(--space-2xl);
  }

  .footer-section {
    padding: var(--space-md);
  }

  .footer-section h4,
  .footer-section h5 {
    color: var(--color-white);
    margin-bottom: var(--space-md);
  }

  .footer-section ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-section ul li {
    margin-bottom: var(--space-sm);
  }

  .footer-section p {
    margin-bottom: var(--space-md);
    line-height: var(--line-height-relaxed);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: var(--space-lg);
    text-align: center;
    color: var(--color-light-gray);
    font-size: var(--font-size-sm);
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
