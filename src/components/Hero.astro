---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  image?: string;
  cta?: {
    text: string;
    href: string;
  };
  background?: 'primary' | 'secondary' | 'accent' | 'white';
}

const { title, subtitle, description, image, cta, background = 'primary' } = Astro.props;
---

<section class="hero" data-bg={background}>
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">{title}</h1>
      {subtitle && <p class="hero-subtitle">{subtitle}</p>}
      {description && <p class="hero-description">{description}</p>}
      {
        cta && (
          <a href={cta.href} class="btn btn-primary">
            {cta.text}
          </a>
        )
      }
    </div>
    {image && <div class="hero-image"><img src={image} alt={title} /></div>}
  </div>
</section>

<style>
  .hero {
    padding: var(--space-4xl) 0;
    display: flex;
    align-items: center;
  }

  .hero[data-bg='primary'] {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: var(--color-white);
  }

  .hero[data-bg='secondary'] {
    background: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-secondary-dark) 100%);
    color: var(--color-white);
  }

  .hero[data-bg='accent'] {
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
    color: var(--color-black);
  }

  .hero[data-bg='white'] {
    background-color: var(--color-white);
    color: var(--color-dark-gray);
  }

  .hero .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .hero-title {
    font-size: var(--font-size-5xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    margin: 0;
  }

  .hero[data-bg='white'] .hero-title {
    color: var(--color-black);
  }

  .hero[data-bg='primary'] .hero-title,
  .hero[data-bg='secondary'] .hero-title {
    color: var(--color-white);
  }

  .hero-subtitle {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-semibold);
    margin: 0;
    opacity: 0.9;
  }

  .hero-description {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    margin: 0;
    opacity: 0.95;
  }

  .hero-image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-image img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .btn {
    align-self: flex-start;
  }

  .hero[data-bg='primary'] .btn-primary,
  .hero[data-bg='secondary'] .btn-primary {
    background-color: var(--color-accent);
    color: var(--color-black);
  }

  .hero[data-bg='primary'] .btn-primary:hover,
  .hero[data-bg='secondary'] .btn-primary:hover {
    background-color: var(--color-accent-light);
  }

  @media (max-width: 768px) {
    .hero .container {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .hero {
      padding: var(--space-2xl) 0;
    }

    .hero-title {
      font-size: var(--font-size-3xl);
    }

    .hero-subtitle {
      font-size: var(--font-size-lg);
    }

    .hero-description {
      font-size: var(--font-size-base);
    }
  }
</style>
