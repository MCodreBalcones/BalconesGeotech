---
interface NavItem {
  label: string;
  href: string;
}

const navItems: NavItem[] = [
  { label: 'Home', href: '/BalconesGeotech/' },
  { label: 'Services', href: '/BalconesGeotech/services' },
  { label: 'Projects', href: '/BalconesGeotech/projects' },
  { label: 'About Us', href: '/BalconesGeotech/about' },
  { label: 'Contact', href: '/BalconesGeotech/contact' },
];
---

<header class="navigation">
  <div class="container">
    <div class="nav-wrapper">
      <div class="logo">
        <a href="/BalconesGeotech/">
          <span class="logo-text">Balcones Geotech</span>
        </a>
      </div>
      <nav class="nav-menu">
        <ul>
          {navItems.map((item) => (
            <li>
              <a href={item.href} class:list={['nav-link']}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  .navigation {
    background-color: var(--color-white);
    border-bottom: 1px solid var(--color-light-gray);
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    box-shadow: var(--shadow-sm);
  }

  .nav-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-md) 0;
  }

  .logo {
    flex-shrink: 0;
  }

  .logo a {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-black);
  }

  .logo-text {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .nav-menu ul {
    display: flex;
    list-style: none;
    gap: var(--space-lg);
    margin: 0;
  }

  .nav-link {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-dark-gray);
    transition: color var(--transition-fast);
    text-decoration: none;
    position: relative;
  }

  .nav-link:hover {
    color: var(--color-primary);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-primary);
    transition: width var(--transition-fast);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  @media (max-width: 768px) {
    .nav-menu ul {
      gap: var(--space-md);
      font-size: var(--font-size-sm);
    }

    .logo-text {
      font-size: var(--font-size-lg);
    }
  }
</style>
